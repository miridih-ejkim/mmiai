# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql://user:password@localhost:5432/miai

# ===== Redis (Memory cache) =====
REDIS_URL=redis://localhost:6379

# ===== MCP: Atlassian (Confluence + Jira) =====
# Option A: Streamable HTTP (Kubernetes 배포 시)
# MCP_ATLASSIAN_URL=http://atlassian-mcp:8080/mcp
# MCP_AUTH_TOKEN=optional-bearer-token

# Option B: stdio (로컬 uvx, pip install mcp-atlassian 필요)
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# ===== MCP: DataHub =====
# Option A: Streamable HTTP (Kubernetes 배포 시)
# MCP_DATAHUB_URL=http://datahub-mcp:8080/mcp

# Option B: stdio (로컬 uvx, pip install mcp-server-datahub 필요)
DATAHUB_GMS_URL=https://datahub.example.com/api/gms
DATAHUB_GMS_TOKEN=your-datahub-token

# ===== MCP: Google Search (로컬 stdio, 항상 필요) =====
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# ===== Shaper (Data Analyst Dashboard) =====
SHAPER_BASE_URL=http://localhost:5454
SHAPER_API_KEY=your-shaper-api-key

# ===== Next.js → Mastra Server 연결 =====
# 로컬 개발 시 기본값 http://localhost:4111 (설정 안 해도 됨)
# Docker/Kubernetes 배포 시 설정 필요
# MASTRA_SERVER_URL=http://mastra-server:4111
