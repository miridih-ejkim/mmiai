        <mxCell id="ambig-candidates-note" parent="o4QgxmDZ_h19-OYWXaL5-9" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=9;shadow=1;align=left;fontStyle=0" value="&lt;b&gt;Plan-level Candidates&lt;/b&gt;&lt;br&gt;&lt;br&gt;candidates: [&lt;br&gt;&amp;nbsp;&amp;nbsp;{ planId, label, description,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;targets[], executionMode,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;expectedOutcome }&lt;br&gt;]&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;단순 Agent 선택이 아닌&lt;br&gt;실행 계획 전체를 선택&lt;/font&gt;" vertex="1">
          <mxGeometry height="140" width="180" x="344" y="595" as="geometry" />
        </mxCell>
        <mxCell id="arch-change-note" parent="o4QgxmDZ_h19-OYWXaL5-9" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#E8F5E9;strokeColor=#43A047;fontSize=9;shadow=1;align=left;fontStyle=0" value="&lt;b&gt;Synthesize-first 아키텍처&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;Before:&lt;/font&gt; agent → quality-check → synthesize&lt;br&gt;&lt;font color=&quot;#43A047&quot;&gt;&lt;b&gt;After:&lt;/b&gt;&lt;/font&gt; agent → &lt;b&gt;synthesize&lt;/b&gt; → quality-check&lt;br&gt;&lt;br&gt;Scorer가 raw MCP 결과가 아닌&lt;br&gt;&lt;b&gt;합성된 자연어 답변&lt;/b&gt;을 평가하므로:&lt;br&gt;• &quot;찾을 수 없었습니다&quot; + 맥락 설명 →&lt;br&gt;&amp;nbsp;&amp;nbsp;usefulness 0.3~0.5 (합당한 답변)&lt;br&gt;• raw &quot;검색 결과 없음&quot; → 무조건 0.0&lt;br&gt;&amp;nbsp;&amp;nbsp;(이전 방식의 문제)" vertex="1">
          <mxGeometry height="170" width="200" x="1750" y="640" as="geometry" />
        </mxCell>
