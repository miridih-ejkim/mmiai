        <mxCell id="scorer-info1" parent="o4QgxmDZ_h19-OYWXaL5-9" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontStyle=0" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;qualityScorer (Haiku Judge)&lt;/b&gt;&lt;br&gt;Pipeline: analyze(&lt;font color=&quot;#E65100&quot;&gt;LLM&lt;/font&gt;) → generateScore(code) → generateReason(code)&lt;br&gt;&lt;br&gt;• &lt;b&gt;Relevance (0.35)&lt;/b&gt;: 응답이 질문에 실제로 답하는가&lt;br&gt;• &lt;b&gt;Completeness (0.30)&lt;/b&gt;: 질문의 모든 측면을 다루는가&lt;br&gt;• &lt;b&gt;Usefulness (0.20)&lt;/b&gt;: 실질적 정보 vs &quot;결과 없음&quot;&lt;br&gt;• &lt;b&gt;Coherence (0.15)&lt;/b&gt;: 구조, 가독성, 논리적 조직화&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#E65100&quot;&gt;&lt;b&gt;※ raw MCP 결과가 아닌 합성된 자연어 답변을 평가&lt;/b&gt;&lt;/font&gt;&lt;br&gt;+ improvementSuggestion → Classifier에 개선 방향 전달&lt;/font&gt;" vertex="1">
          <mxGeometry height="180" width="340" x="1775" y="415" as="geometry" />
        </mxCell>
        <mxCell id="qc-stage1-note" parent="o4QgxmDZ_h19-OYWXaL5-9" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontStyle=0" value="&lt;font style=&quot;font-size:9px&quot; color=&quot;#b85450&quot;&gt;&lt;b&gt;Stage 1 (code):&lt;/b&gt; success===false || empty → 즉시 FAIL (LLM 호출 없음)&lt;br&gt;&lt;b&gt;Stage 2 (LLM):&lt;/b&gt; qualityScorer(Haiku) → &lt;font color=&quot;#E65100&quot;&gt;합성된 답변&lt;/font&gt; 의미 기반 평가 → PASS/FAIL&lt;br&gt;&lt;b&gt;Same-targets guard:&lt;/b&gt; 동일 targets 2회+ 실패 시 재시도 중단 → PASS&lt;br&gt;&lt;b&gt;FAIL시:&lt;/b&gt; RetryEntry 생성 → retryHistory[] 누적 → retryCount++&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="420" x="670" y="900" as="geometry" />
        </mxCell>
        <mxCell id="retry-history-note" parent="o4QgxmDZ_h19-OYWXaL5-9" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=9;shadow=1;align=left;fontStyle=0" value="&lt;b&gt;[RETRY HISTORY] 주입&lt;/b&gt;&lt;br&gt;&lt;br&gt;retryHistory &amp;gt; 0일 때 프롬프트에 주입:&lt;br&gt;• Attempt N: targets, queries, reason&lt;br&gt;• confidence (Worker 자기 확신도)&lt;br&gt;• improvementSuggestion (Scorer)&lt;br&gt;&lt;br&gt;이미 시도한 전략의 반복 방지" vertex="1">
          <mxGeometry height="130" width="180" x="1556" y="960" as="geometry" />
        </mxCell>
        <mxCell id="e-ambig2candidates" edge="1" parent="o4QgxmDZ_h19-OYWXaL5-9" source="suspend-ambiguous" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#1565C0;dashed=1;fontSize=9;fontStyle=0" target="ambig-candidates-note" value="\">
